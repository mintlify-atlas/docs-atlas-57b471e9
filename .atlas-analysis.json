  "keyFeatures": [
    "Unified Step primitive for all backend patterns",
    "Multi-language support (TypeScript, JavaScript, Python)",
    "HTTP APIs with validation and middleware",
    "Background jobs and queues",
    "Cron scheduling",
    "Real-time streaming",
    "State management",
    "AI agent integration",
    "Built-in observability",
