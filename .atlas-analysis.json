  "publicApiSurface": [
    "step() - Create a Step with config and handler",
    "http() - HTTP trigger factory",
    "queue() - Queue trigger factory",
    "cron() - Cron trigger factory",
    "state() - State trigger factory",
    "stream() - Stream trigger factory",
    "FlowContext - Handler context with enqueue, state, logger, streams",
    "StateManager - State management API",
    "Stream - Real-time streaming API",
    "ApiRequest - HTTP request type",
    "ApiResponse - HTTP response type",
    "Enqueuer - Queue enqueue function",
    "multiTriggerStep() - Multi-trigger step builder",
    "initIII() - Initialize iii engine",
    "Motia - Core runtime class"
  ]
